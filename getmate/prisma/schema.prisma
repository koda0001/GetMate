// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
  provider = "cockroachdb"
  url      = env("DATABASE_URL") // DO NOT REMOVE THIS LINE! Required for Prisma CLI.
  // url property deprecated in Prisma 7, see prisma.config.ts for connection
}

model Post {
    id        Int      @id @default(sequence())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    applications  Application[]
    availability  String    @default("Available")
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    bio           String?
    posts         Post[]
    techStack      String[]
    projects      Project[]
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

enum ProjectCategory {
  WEB
  MOBILE
  GAME
  AI
}

enum ProjectStatus {
  HIRING
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Project {
  id             String   @id @default(cuid())
  title          String
  description    String
  slots          Int
  subscribers    String[] // user IDs
  roleDefinitions String[]
  private        Boolean  @default(false)
  github         String?
  link           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt @default(now())
  author         User     @relation(fields: [authorId], references: [id])
  authorId       String
  techStack      String[]
  category       ProjectCategory @default(WEB)
  status         ProjectStatus   @default(HIRING)
  applications   Application[]

  // Removed invalid @@index([name]) - no 'name' field exists
}

model Application {
  id         String            @id @default(cuid())
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  slotIndex  Int
  status     ApplicationStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  role       String

  @@unique([userId, projectId, slotIndex])
}